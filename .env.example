# Site (optional – defaults used if unset)
# NEXT_PUBLIC_SITE_URL=https://dread.lol  # Build-time; use for client-side
# SITE_URL=https://dread.lol               # Runtime override (Polar redirects, auth). Use in Docker.
# For wildcard subdomains (*.dread.lol), subdomain detection and cookie domain derive base from SITE_URL. Override with:
# NEXT_PUBLIC_SITE_DOMAIN=dread.lol
# Session cookie uses Domain=.dread.lol so sign-in works on apex and all subdomains. Set NEXT_PUBLIC_SITE_DOMAIN to your apex (no subdomain).
# Optional: SECURE_COOKIE=false to disable Secure on cookies when testing HTTP against a production build (default: Secure in production).

# Databases (Docker Compose defaults: mongodb://dread:dread@localhost:27017/dread?authSource=admin, redis://localhost:6379)
# DATABASE_URL=mongodb://dread:dread@localhost:27017/dread?authSource=admin
# VALKEY_URL=redis://localhost:6379

# User uploads (avatars, backgrounds, gallery, etc.)
#
# Option A — S3-compatible storage (AWS S3, Cloudflare R2, MinIO, etc.): new uploads go here when set.
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# For R2, use e.g. S3_REGION=auto and S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional: S3_UPLOAD_PREFIX=uploads   # object key prefix (default uploads)
# Optional: S3_FORCE_PATH_STYLE=true   # some MinIO setups
#
# Option B — local directory (Docker volume). Still used as fallback for legacy blobs if both are set.
# FILE_STORAGE_PATH=./data/uploads
#
# At least one of S3 (bucket + region) or FILE_STORAGE_PATH is required for /api/upload and /api/files.
# DEBUG_FILE_STORAGE=1   # verbose server logs for storage readiness (S3 probe, disk path); failures always log a [FILE_STORAGE] warn

# Discord OAuth – create an app at https://discord.com/developers/applications
# In the app, OAuth2 → Redirects: add http://localhost:3000/api/auth/discord/callback (and your production URL)
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Roblox OAuth – link Roblox accounts for profile widgets
# Create app at https://create.roblox.com/dashboard/credentials (OAuth tab)
# Add redirect: {SITE_URL}/api/auth/roblox/callback
# ROBLOX_OAUTH_CLIENT_ID=
# ROBLOX_OAUTH_CLIENT_SECRET=
# ROBLOX_OAUTH_REDIRECT_URI=  # optional; defaults to SITE_URL + /api/auth/roblox/callback

# Discord presence bot (optional – for live status + Rich Presence on profiles)
# Create a Bot in the same Discord app; enable Privileged Gateway Intent: PRESENCE INTENT.
# Add the bot to your server; set DISCORD_GUILD_ID to that server’s ID to only sync members from that server.
# Local: npm run discord-presence-bot. Production: dread-bot service in docker-compose.coolify.yml.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# GitHub profile widgets (optional) — server-side token; users only enter their GitHub username in the dashboard.
# Contribution heatmap uses the GraphQL API (see https://docs.github.com/en/graphql); last push / public repos use REST (https://docs.github.com/en/rest).
# Create a PAT: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens
# Overview: https://docs.github.com/en/authentication — classic PAT: scope read:user is enough for public profile + contribution calendar.
# GITHUB_TOKEN=

# Debug (only enable when needed; logs may contain sensitive data):
# DEBUG_DISCORD_FLAGS=1   - Discord badge lookup
# DEBUG_CHECKOUT=1        - Polar checkout redirect (origin, URLs, headers)
# DEBUG=1                 - Enable all debug topics

# Polar – payments & subscriptions (https://polar.sh)
# Create an Organization Access Token in organization settings.
# POLAR_ACCESS_TOKEN=polar_pat_...
# POLAR_WEBHOOK_SECRET=...  # From webhook endpoint settings (sign requests)
# POLAR_SANDBOX=1           # Use sandbox for local/testing; omit for production
# Product IDs are configured in Admin → Billing (not env)

# Session signing – generate with: openssl rand -base64 32
AUTH_SECRET=

# System monitoring → Discord (optional). Protects GET /api/cron/monitoring; schedule with Coolify/cron + Authorization: Bearer
# CRON_SECRET=

# Local accounts (email + SRP-6a + optional WebAuthn passkeys) — https://resend.com
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com
#
# WebAuthn (passkeys). RP ID defaults to hostname from SITE_URL; override for local dev:
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:3000

# Optional: MongoDB (when not using Docker Compose defaults)
# MONGO_USER=dread
# MONGO_PASSWORD=dread
# MONGO_DB=dread
