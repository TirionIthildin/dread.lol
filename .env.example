# Site (optional – defaults used if unset)
# NEXT_PUBLIC_SITE_URL=https://dread.lol  # Build-time; use for client-side
# SITE_URL=https://dread.lol               # Runtime override (Polar redirects, auth). Use in Docker.
# For wildcard subdomains (*.dread.lol), subdomain detection and cookie domain derive base from SITE_URL. Override with:
# NEXT_PUBLIC_SITE_DOMAIN=dread.lol

# Databases (Docker Compose defaults: mongodb://dread:dread@localhost:27017/dread?authSource=admin, redis://localhost:6379)
# DATABASE_URL=mongodb://dread:dread@localhost:27017/dread?authSource=admin
# VALKEY_URL=redis://localhost:6379

# SeaweedFS (internal – for image uploads). Local dev: http://localhost:9333; Docker/Coolify: http://seaweed-master:9333
# SEAWEED_MASTER_URL=http://localhost:9333
# When app runs on host but SeaweedFS in Docker, set so file fetches work (master returns unreachable hostnames):
# SEAWEED_VOLUME_PUBLIC_URL=http://localhost:8080

# Discord OAuth – create an app at https://discord.com/developers/applications
# In the app, OAuth2 → Redirects: add http://localhost:3000/api/auth/discord/callback (and your production URL)
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Roblox OAuth – link Roblox accounts for profile widgets
# Create app at https://create.roblox.com/dashboard/credentials (OAuth tab)
# Add redirect: {SITE_URL}/api/auth/roblox/callback
# ROBLOX_OAUTH_CLIENT_ID=
# ROBLOX_OAUTH_CLIENT_SECRET=
# ROBLOX_OAUTH_REDIRECT_URI=  # optional; defaults to SITE_URL + /api/auth/roblox/callback

# Discord presence bot (optional – for live status + Rich Presence on profiles)
# Create a Bot in the same Discord app; enable Privileged Gateway Intent: PRESENCE INTENT.
# Add the bot to your server; set DISCORD_GUILD_ID to that server’s ID to only sync members from that server.
# Local: npm run discord-presence-bot. Production: dread-bot service in docker-compose.coolify.yml.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Debug Discord badge lookup (logs to server when set): DEBUG_DISCORD_FLAGS=1

# Polar – payments & subscriptions (https://polar.sh)
# Create an Organization Access Token in organization settings.
# POLAR_ACCESS_TOKEN=polar_pat_...
# POLAR_WEBHOOK_SECRET=...  # From webhook endpoint settings (sign requests)
# POLAR_SANDBOX=1           # Use sandbox for local/testing; omit for production
# Product IDs are configured in Admin → Billing (not env)

# Session signing – generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional: MongoDB (when not using Docker Compose defaults)
# MONGO_USER=dread
# MONGO_PASSWORD=dread
# MONGO_DB=dread
