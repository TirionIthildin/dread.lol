{
  "name": "dread-lol",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names next,bot -c blue,magenta \"next dev\" \"node --env-file=.env scripts/discord-presence-bot.mjs\"",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:migrate-prod": "node scripts/migrate.mjs",
    "discord-presence-bot": "node --env-file=.env scripts/discord-presence-bot.mjs",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --project=chromium",
    "prepare": "husky"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "@polar-sh/nextjs": "^0.9.5",
    "@polar-sh/sdk": "^0.46.5",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "discord.js": "^14.25.1",
    "ioredis": "^5.10.1",
    "mongodb": "^7.1.0",
    "next": "^16.2.0",
    "otpauth": "^9.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "resend": "^6.9.4",
    "sonner": "^2.0.7",
    "undici": "^6.24.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "undici": "^6.24.1"
  }
}
